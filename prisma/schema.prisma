// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  alias_name   String?
  harems       Harem[]
  tags         Tag[]
  userLocation String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Harem {
  id        Int        @id @default(autoincrement())
  name      String
  user      User?      @relation(fields: [userId], references: [id])
  userId    Int?
  prospects Prospect[]
  order     Int        @default(0)
}

model Prospect {
  id                 Int      @id @default(autoincrement())
  name               String
  harem              Harem?   @relation(fields: [haremId], references: [id])
  haremId            Int?
  hotLead            Boolean  @default(false)
  haremOrder         Int      @default(0)
  timeInCurrentHarem DateTime @default(now())
  // Prospect Details
  phoneNumber        String   @default("")
  location           String   @default("")
  age                Int?
  occupation         String   @default("")

  notes     ProspectNote[]
  tags      ProspectTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
}

model Tag {
  id        Int           @id @default(autoincrement())
  name      String
  user      User          @relation(fields: [userId], references: [id])
  userId    Int
  prospects ProspectTag[]
  createdAt DateTime      @default(now())

  @@unique([userId, name])
}

model ProspectNote {
  id         Int      @id @default(autoincrement())
  content    String
  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProspectTag {
  prospect   Prospect @relation(fields: [prospectId], references: [id])
  prospectId Int
  tag        Tag      @relation(fields: [tagId], references: [id])
  tagId      Int

  @@id([prospectId, tagId])
}
